APP_NAME="AgroOps Copilot API"
ENVIRONMENT=local

# Default works offline for local development and tests.
LLM_PROVIDER=mock
LLM_MODEL=mock-agronomy-advisor
LLM_TEMPERATURE=0.2

# OpenRouter example:
# LLM_PROVIDER=openrouter
# LLM_MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=your_key_here
# OPENROUTER_SITE_URL=https://github.com/your-user/agroops-copilot-api
# OPENROUTER_APP_NAME="AgroOps Copilot API"

# OpenAI example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_key_here

# Groq example:
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=your_key_here

# Hash embeddings are deterministic and offline. For better semantic retrieval:
# pip install -e ".[embeddings]"
# EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSIONS=384
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

CHROMA_PATH=data/chroma
CHROMA_COLLECTION=agroops_documents
RAG_TOP_K=5
CHUNK_SIZE=900
CHUNK_OVERLAP=150
MAX_CONTEXT_CHARS=7000

